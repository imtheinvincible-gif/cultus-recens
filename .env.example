# ============================================================
# Cultus Recens — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- App Config ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Admin Authentication (REQUIRED) ---
# Change these before deploying to production!
ADMIN_EMAIL=admin@cultusrecens.com
ADMIN_PASSWORD=change-me-before-deploying

# --- Session Security (REQUIRED) ---
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret-string

# --- Customer Demo Account (optional, for staging only) ---
DEMO_USER_EMAIL=user@example.com
DEMO_USER_PASSWORD=change-me
DEMO_USER_NAME=Demo User

# --- Stripe (REQUIRED for real payments) ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Database (REQUIRED for Prisma) ---
# Example: postgresql://user:password@host:5432/cultus_recens
DATABASE_URL=postgresql://...
